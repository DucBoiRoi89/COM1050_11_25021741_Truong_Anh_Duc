<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="CENTER" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AuctionController">
    <padding><Insets top="50" right="50" bottom="50" left="50"/></padding>
    <Label fx:id="lblCurrentPrice" text="Giá hiện tại: 0 VNĐ" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="txtBidAmount" promptText="Nhập giá tiền..."/>
        <Button text="ĐẶT GIÁ" onAction="#onPlaceBidClick" style="-fx-background-color: #dca742; -fx-text-fill: white;"/>
    </HBox>
    <Button text="QUAY LẠI TRANG CHỦ" onAction="#handleGoToHome" style="-fx-cursor: hand;" /> 
</VBox>