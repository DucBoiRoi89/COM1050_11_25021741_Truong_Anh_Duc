<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0" prefWidth="1200.0" style="-fx-background-color: #f4f4f4;" 
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="controller.AdminDashboardController">
   <left>
      <VBox prefWidth="250.0" spacing="10.0" style="-fx-background-color: #1a1a1a;">
         <padding><Insets bottom="20.0" left="20.0" right="20.0" top="40.0" /></padding>
         <children>
            <Label text="ADMIN PANEL" textFill="#deff9a">
               <font><Font name="System Bold" size="24.0" /></font>
               <VBox.margin><Insets bottom="30.0" /></VBox.margin>
            </Label>
            <Button onAction="#showStatistics" prefWidth="Infinity" style="-fx-background-color: #333; -fx-text-fill: white;" text="📊 Thống kê tổng quan" />
            <Button onAction="#manageUsers" prefWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #ccc;" text="👥 Quản lý người dùng" />
            <Button onAction="#manageAuctions" prefWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #ccc;" text="🔨 Giám sát đấu giá" />
            <Region VBox.vgrow="ALWAYS" />
            <Button onAction="#handleLogout" prefWidth="Infinity" style="-fx-background-color: #dc3545; -fx-text-fill: white;" text="Đăng xuất" />
         </children>
      </VBox>
   </left>
   <center>
      <VBox spacing="25.0">
         <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
         <children>
            <HBox spacing="20.0">
               <children>
                  <VBox prefWidth="280.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                     <children>
                        <Label text="Tổng số người dùng" textFill="#666" />
                        <Label fx:id="lblTotalUsers" style="-fx-font-size: 32; -fx-font-weight: bold;" text="0" />
                     </children>
                  </VBox>
                  <VBox prefWidth="280.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                     <children>
                        <Label text="Phiên đang diễn ra" textFill="#666" />
                        <Label fx:id="lblActiveAuctions" style="-fx-font-size: 32; -fx-font-weight: bold;" text="0" textFill="#28a745" />
                     </children>
                  </VBox>
                  <VBox prefWidth="280.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                     <children>
                        <Label text="Doanh thu (Phí sàn)" textFill="#666" />
                        <Label fx:id="lblTotalRevenue" style="-fx-font-size: 32; -fx-font-weight: bold;" text="0 VNĐ" textFill="#dca742" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">
               <children>
                  <Label text="DANH SÁCH NGƯỜI DÙNG HỆ THỐNG" style="-fx-font-weight: bold; -fx-font-size: 18;" />
                  <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS" stylesheets="@style.css">
                    <columns>
                      <TableColumn fx:id="colUserId" prefWidth="80.0" text="ID" />
                      <TableColumn fx:id="colUsername" prefWidth="150.0" text="Tên đăng nhập" />
                      <TableColumn fx:id="colFullName" prefWidth="200.0" text="Họ và tên" />
                      <TableColumn fx:id="colRole" prefWidth="120.0" text="Vai trò" />
                      <TableColumn fx:id="colBalance" prefWidth="150.0" text="Số dư" />
                      <TableColumn fx:id="colStatus" prefWidth="120.0" text="Trạng thái" />
                    </columns>
                  </TableView>
                  <HBox alignment="CENTER_RIGHT" spacing="10.0">
                     <children>
                        <Button onAction="#handleLockUser" style="-fx-background-color: #dc3545; -fx-text-fill: white;" text="Khóa tài khoản" />
                        <Button onAction="#handleUnlockUser" style="-fx-background-color: #28a745; -fx-text-fill: white;" text="Mở khóa" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>