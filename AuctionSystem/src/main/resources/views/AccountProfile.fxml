<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #f8f9fa;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="controller.AuctionListController">
   <top>
      <VBox alignment="CENTER" prefHeight="125.0" style="-fx-background-color: #1a1a1a;">
         <padding><Insets bottom="20.0" top="20.0" /></padding>
         <children><Label text="UET AUCTIONS" textFill="#dca742"><font><Font size="36.0" /></font></Label></children>
      </VBox>
   </top>
   <left>
      <VBox prefWidth="200.0" spacing="10.0" style="-fx-background-color: #404040;">
         <padding><Insets bottom="20.0" left="20.0" right="20.0" top="30.0" /></padding>
         <children>
            <Button onAction="#handleGoToHome" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #e0e0e0; -fx-cursor: hand;" text="Trang chủ" />
            <Button onAction="#handleGoToProfile" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #dca742; -fx-font-weight: bold; -fx-cursor: hand;" text="Tài khoản" />
            <Button onAction="#handleGoToHistory" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #e0e0e0; -fx-cursor: hand;" text="Lịch sử đấu giá" />
            
            <Region VBox.vgrow="ALWAYS" />
            <Button onAction="#handleLogout" prefWidth="200.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="ĐĂNG XUẤT" />
         </children>
      </VBox>
   </left>
   <center>
      <VBox spacing="30.0" style="-fx-background-color: white;">
         <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <StackPane style="-fx-background-color: #e0e0e0; -fx-background-radius: 40; -fx-min-width: 80; -fx-min-height: 80;">
                     <children><Label style="-fx-font-size: 40;" text="👤" /></children>
                  </StackPane>
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label fx:id="lblFullNameHeader" style="-fx-font-weight: bold; -fx-font-size: 18;" text="Đang tải..." />
                        <Label fx:id="lblUserRole" text="Vai trò hệ thống" textFill="#dca742" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <GridPane hgap="15.0" vgap="15.0">
               <columnConstraints>
                  <ColumnConstraints minWidth="150.0" />
                  <ColumnConstraints hgrow="ALWAYS" />
               </columnConstraints>
               <children>
                  <Label text="Mã người dùng:" GridPane.rowIndex="0" />
                  <TextField fx:id="txtUserId" editable="false" style="-fx-background-color: #eee;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  
                  <Label text="Họ và tên:" GridPane.rowIndex="1" />
                  <TextField fx:id="txtFullName" editable="false" style="-fx-background-color: #eee;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                  <Label text="Số dư tài khoản:" GridPane.rowIndex="2" />
                  <TextField fx:id="txtBalance" editable="false" style="-fx-background-color: #eee; -fx-text-fill: #28a745; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
               </children>
            </GridPane>
            
            <VBox fx:id="extraInfoContainer" spacing="10" style="-fx-background-color: #1a1a1a; -fx-padding: 25; -fx-background-radius: 10;">
               <children>
                  <Label fx:id="lblExtraTitle" text="Thông tin bổ sung:" textFill="WHITE" />
                  <Label fx:id="lblExtraValue" style="-fx-font-size: 20;" text="..." textFill="#dca742" />
               </children>
            </VBox>
         </children>
      </VBox>
   </center>
</BorderPane>