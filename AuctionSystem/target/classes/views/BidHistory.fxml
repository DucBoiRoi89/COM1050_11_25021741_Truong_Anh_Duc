<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #f8f9fa;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="controller.AuctionListController">
   <top>
      <VBox alignment="CENTER" prefHeight="125.0" style="-fx-background-color: #1a1a1a;">
         <children><Label text="UET AUCTIONS" textFill="#dca742"><font><Font name="System Bold" size="36.0" /></font></Label></children>
      </VBox>
   </top>
   <left>
      <VBox prefWidth="200.0" spacing="10.0" style="-fx-background-color: #404040;">
         <padding><Insets bottom="20.0" left="20.0" right="20.0" top="30.0" /></padding>
         <children>
            <Button onAction="#handleGoToHome" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #e0e0e0;" text="Trang chủ" />
            <Button onAction="#handleGoToProfile" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #e0e0e0;" text="Tài khoản" />
            <Button onAction="#handleGoToHistory" prefWidth="200.0" style="-fx-background-color: transparent; -fx-text-fill: #dca742; -fx-font-weight: bold;" text="Lịch sử đấu giá" />
            <Region VBox.vgrow="ALWAYS" />
            <Button onAction="#handleLogout" prefWidth="200.0" style="-fx-background-color: #dc3545; -fx-text-fill: white;" text="ĐĂNG XUẤT" />
         </children>
      </VBox>
   </left>
   <center>
      <VBox spacing="20.0" style="-fx-background-color: white;">
         <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
         <children>
            <Label text="LỊCH SỬ GIAO DỊCH ĐẤU GIÁ" style="-fx-font-weight: bold; -fx-font-size: 22;" />
            <TableView fx:id="historyTable" stylesheets="@style.css" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colItemName" prefWidth="300.0" text="Tên sản phẩm" />
                  <TableColumn fx:id="colBidAmount" prefWidth="200.0" text="Giá bạn đã đặt" />
                  <TableColumn fx:id="colBidTime" prefWidth="250.0" text="Thời gian đặt giá" />
               </columns>
               <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </center>
</BorderPane>